---
import type { Hack } from "../lib/patcher";

interface Props {
  gameId: string;
  hacks: Hack[];
}

const { gameId, hacks } = Astro.props;
---

<fieldset class="hacks-section">
  <legend class="section-label">Hacks to apply</legend>
  <ul class="hack-list">
    {
      hacks.map((hack, i) => (
        <li class="hack-item">
          <label class="hack-label">
            <input
              type="checkbox"
              class="hack-checkbox"
              name={`hack-${gameId}`}
              value={i}
              checked
            />
            <span>{hack.description}</span>
            {hack.author && <span class="hack-author">by {hack.author}</span>}
          </label>
        </li>
      ))
    }
  </ul>
</fieldset>

<style>
  .hacks-section {
    border: none;
    padding: 0;
    min-width: 0;
  }
  .section-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: 0.6rem;
  }
  .hack-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }
  .hack-item {
    padding: 0.45rem 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 5px;
    transition:
      background 0.15s,
      border-color 0.15s;
  }
  .hack-item:has(input:checked) {
    background: color-mix(in srgb, var(--accent, #4f8ef7) 10%, var(--bg));
    border-color: color-mix(in srgb, var(--accent, #4f8ef7) 40%, var(--border));
  }
  .hack-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    font-size: 0.875rem;
  }
  .hack-author {
    font-size: 0.78rem;
    color: var(--muted);
    margin-left: auto;
  }
  .hack-label input[type="checkbox"] {
    cursor: pointer;
    accent-color: var(--accent);
    flex-shrink: 0;
  }
</style>
